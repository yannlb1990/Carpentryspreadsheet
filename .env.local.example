# ─────────────────────────────────────────────────────────────────────────────
# Carpentry Shop — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# 1. Copy this file:  cp .env.local.example .env.local
# 2. Fill in all values
# 3. Never commit .env.local to git
# ─────────────────────────────────────────────────────────────────────────────

# ── Admin Panel ───────────────────────────────────────────────────────────────
# Password to access /admin — choose something strong
ADMIN_PASSWORD=change-me-to-something-strong

# ── Stripe Keys ───────────────────────────────────────────────────────────────
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ── Stripe Price IDs ──────────────────────────────────────────────────────────
# Dashboard → Products → Add product → set price → copy Price ID (price_...)
#   Carpentry Estimation 2026:          $29.90 AUD  one-time
#   Australian Carpentry Pricing Guide: $9.99  AUD  one-time
#   Complete Bundle:                    $34.99 AUD  one-time
STRIPE_PRICE_ESTIMATION=price_...
STRIPE_PRICE_PRICEGUIDE=price_...
STRIPE_PRICE_BUNDLE=price_...

# ── Stripe Webhook ────────────────────────────────────────────────────────────
# Get from Stripe Dashboard → Webhooks → Add endpoint
# URL: https://yourdomain.com/api/webhooks/stripe
# Event: checkout.session.completed
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Email (Resend) ────────────────────────────────────────────────────────────
# https://resend.com — verify your sending domain (carpentrypro.com.au)
# Sends order confirmation emails as backup when Stripe redirect fails
RESEND_API_KEY=re_...

# ── Vercel Blob (production only) ─────────────────────────────────────────────
# Vercel sets this automatically when you enable Blob storage in your project.
# Leave blank for local dev — files are served from the /files directory instead.
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# ── Base URL ──────────────────────────────────────────────────────────────────
# Local:
NEXT_PUBLIC_BASE_URL=http://localhost:3002
# Production (Vercel): set to your domain, e.g. https://carpentrypro.com.au
